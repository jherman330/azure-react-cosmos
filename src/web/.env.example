# API
VITE_API_BASE_URL=http://localhost:3100

# Optional: Application Insights
# VITE_APPLICATIONINSIGHTS_CONNECTION_STRING=

# Microsoft Entra ID (MSAL)
# Leave VITE_MSAL_CLIENT_ID unset = LOCAL DEV ONLY: no sign-in, no API tokens (see docs/auth-msal.md).
# VITE_MSAL_CLIENT_ID=
# VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
# VITE_MSAL_REDIRECT_URI=http://localhost:5173
# VITE_MSAL_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
# VITE_MSAL_API_SCOPES=api://your-api-app-id/access_as_user
