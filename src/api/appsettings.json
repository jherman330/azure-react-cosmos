{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cache": {
    "OperationTimeoutSeconds": 2
  },
  "Resilience": {
    "Http": {
      "Retry": {
        "MaxRetryAttempts": 3,
        "BackoffType": "Exponential",
        "UseJitter": true,
        "Delay": "00:00:02"
      },
      "CircuitBreaker": {
        "FailureRatio": 0.1,
        "MinimumThroughput": 10,
        "SamplingDuration": "00:00:30",
        "BreakDuration": "00:00:05"
      },
      "TotalRequestTimeout": {
        "Timeout": "00:00:30"
      },
      "AttemptTimeout": {
        "Timeout": "00:00:10"
      }
    }
  }
}
